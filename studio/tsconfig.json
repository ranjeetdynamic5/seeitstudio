{
  "compilerOptions": {
    "target": "ES2017",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["."]
}
